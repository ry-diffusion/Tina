// ============== REPAIRING OVERLAY ==============

import { Palette, ProgressIndicator } from "std-widgets.slint";
import { Icon } from "../components/icon.slint";
import { RepairProgress } from "../globals.slint";

export component RepairingOverlay inherits Rectangle {
    background: Palette.background.transparentize(0.05);

    // Bloqueia cliques na UI por trás durante o reparo.
    TouchArea { }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 420px;
        height: 240px;
        border-radius: 16px;
        background: Palette.alternate-background;
        border-width: 1px;
        border-color: Palette.border;
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000060;

        VerticalLayout {
            padding: 24px;
            spacing: 16px;
            alignment: center;

            HorizontalLayout {
                alignment: center;
                Icon {
                    width: 40px;
                    height: 40px;
                    source: @image-url("../icons/wrench.svg");
                    icon-color: #25D366;
                }
            }

            Text {
                text: "Reparando";
                font-size: 20px;
                font-weight: 600;
                color: Palette.foreground;
                horizontal-alignment: center;
            }

            Text {
                text: RepairProgress.stage;
                font-size: 13px;
                color: Palette.foreground.transparentize(0.4);
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            // Barra: determinada quando total > 0, indeterminada caso contrário.
            ProgressIndicator {
                indeterminate: RepairProgress.indeterminate || RepairProgress.total <= 0;
                progress: RepairProgress.total > 0
                    ? RepairProgress.current / RepairProgress.total
                    : 0;
            }

            // Contador "current / total" quando faz sentido.
            if !RepairProgress.indeterminate && RepairProgress.total > 0: Text {
                text: RepairProgress.current + " / " + RepairProgress.total;
                font-size: 12px;
                color: Palette.foreground.transparentize(0.5);
                horizontal-alignment: center;
            }
        }
    }
}
